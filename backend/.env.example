# إعدادات الخادم
NODE_ENV=development
PORT=5000

# قاعدة البيانات
MONGO_URI=mongodb://localhost:27017/ctgpro

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=7d

# رابط الواجهة الأمامية
FRONTEND_URL=http://localhost:5173

# البريد الإلكتروني
EMAIL_ENABLED=true
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM_NAME=CTGPRO
EMAIL_FROM_ADDRESS=your-email@gmail.com

# APIs الألعاب (اختيارية)
PUBG_API_KEY=your_pubg_api_key
FREEFIRE_API_KEY=your_freefire_api_key
MLBB_API_KEY=your_mlbb_api_key

# APIs مشغلي الهاتف (اختيارية)
DJEZZY_API_KEY=your_djezzy_api_key
OOREDOO_API_KEY=your_ooredoo_api_key
MOBILIS_API_KEY=your_mobilis_api_key

# إعدادات الدفع (اختيارية)
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
STRIPE_SECRET_KEY=your_stripe_secret_key